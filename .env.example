# ============================================================
#  DGM Service API — Environment Variables
#  Copy this file to .env and fill in all values.
#  NEVER commit .env to source control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Twilio ───────────────────────────────────────────────────
# Found in: twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# The phone number you purchased in Twilio (E.164 format)
TWILIO_FROM_NUMBER=+16155550000

# ── Stripe ───────────────────────────────────────────────────
# Found in: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your-stripe-secret-key-here
# Found in: dashboard.stripe.com/webhooks (after registering endpoint)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Business Identity ─────────────────────────────────────────
# Change these for each new client deployment
BUSINESS_NAME=Donaldson General Maintenance
BUSINESS_SHORT_NAME=DGM
BUSINESS_TAGLINE=Here when you need us most
OWNER_PHONE=+16155550001

# ── Timezone ─────────────────────────────────────────────────
# Use standard Java timezone IDs
# Nashville: America/Chicago
# Dallas:    America/Chicago
# New York:  America/New_York
# Denver:    America/Denver
# LA:        America/Los_Angeles
BUSINESS_TIMEZONE=America/Chicago

# ── Pricing ──────────────────────────────────────────────────
# Dollar amount added to invoices for after-hours jobs
AFTER_HOURS_SURCHARGE=25.00
